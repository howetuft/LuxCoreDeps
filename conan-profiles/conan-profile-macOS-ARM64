include(conan-profile-common)

[settings]
os=Macos
# TODO
# 14.2 is required by opensubdiv for metal
#os.version=15.6
arch=armv8
compiler=clang
compiler.version=20
compiler.cppstd={{ os.getenv("CXX_VERSION") }}
compiler.libcxx=libc++

#TODO
#compiler=apple-clang
#compiler.version=16.0
